# Required environment variables for the IDMC MCP Server container.
# Copy this to container.env (or set these in your cloud provider's secret manager).

# Fernet encryption key — used to encrypt/decrypt credential tokens.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Changing this key invalidates ALL existing tokens.
ENCRYPTION_KEY=your-fernet-key-here

# Password users must provide on the /enroll page to generate a token.
# Share this only with people you want to allow access to this server.
ENROLL_PASSWORD=your-enrollment-password-here

# Public URL of the server — required on Cloud Run to fix host header validation.
# Leave blank for local Docker usage.
# Example: https://idmc-mcp-server-668103879510.us-central1.run.app
SERVER_URL=
