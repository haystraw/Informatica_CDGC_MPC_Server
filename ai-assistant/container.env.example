# URL of the deployed idmc-mcp-server (no trailing slash)
MCP_SERVER_URL=https://idmc-mcp-server-668103879510.us-central1.run.app

# Fernet encryption key — must match the one used by idmc-mcp-server
ENCRYPTION_KEY=your-fernet-key-here

# GCP project (optional on Cloud Run — uses default service account)
GCP_PROJECT=gcp-informatica-sales-sc-emea
GCP_LOCATION=us-central1

# Gemini model to use
GEMINI_MODEL=gemini-2.0-flash-001
